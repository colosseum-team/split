# Copy to backend/.env and fill in values for local dev.

# REQUIRED
# Postgres connection string.
# When running through docker compose: postgres://split:split@postgres:5432/split
# When running backend on host against the dockered DB: postgres://split:split@localhost:5432/split
DATABASE_URL=postgres://split:split@localhost:5432/split

# JWT signing secret. Generate a random 32+ char string for prod.
JWT_SECRET=dev-only-jwt-secret-change-me-please

# OPTIONAL (sensible defaults)
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:3001

MOCK_CHAIN=true
SOLANA_RPC_URL=https://api.devnet.solana.com

# AI arbiter on-chain auto-execution.
# Off by default — frontend QVAC produces a verdict, backend stores it,
# but funds are not moved without manual or on-chain approval.
# Enable on demo only when ResolveDispute is wired into the Anchor program
# AND ARBITER_PRIVATE_KEY is set (base64 secret key, or JSON byte array).
ARBITER_AUTOEXECUTE=false
ARBITER_PRIVATE_KEY=

# QVAC backend inference (contract copilot + dispute brief).
# Requires @qvac/* packages installed in backend workspace.
QVAC_ENABLED=true
QVAC_MODEL_ID=qvac-llamacpp
QVAC_MODEL_VERSION=0.17.4
# QVAC Bare worker IPC (ms). Patched `@qvac/sdk`. Docker Compose sets 900000 for backend.
QVAC_RPC_INIT_TIMEOUT_MS=900000
