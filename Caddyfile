# Caddy config for the split production stack.
#
# Caddy terminates TLS, auto-acquires a Let's Encrypt cert for escros.work.gd
# (HTTP-01 challenge on :80), and proxies everything to the frontend nginx
# inside the compose network. The frontend nginx already knows how to split
# `/api/*` to the backend container, so Caddy only needs one upstream.
#
# Requires:
#   - Oracle Security List opens TCP/UDP 80 and TCP/UDP 443 to 0.0.0.0/0.
#   - DNS A record `escros.work.gd → 84.235.174.228` (already done).

{
	email l2aggron@gmail.com
}

escros.work.gd {
	encode gzip zstd
	reverse_proxy frontend:80
}
