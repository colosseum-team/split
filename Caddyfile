# Caddy config for the split production stack.
#
# Caddy terminates TLS, auto-acquires Let's Encrypt certs (HTTP-01 challenge
# on :80), redirects HTTP→HTTPS automatically, and proxies into the compose
# network. Two virtual hosts:
#
#   escros.work.gd     → landing (Next.js, marketing site, "Try the demo" CTA)
#   app.escros.work.gd → frontend nginx (SPA + /api/* → backend)
#
# Requires DNS A records for both names → 84.235.174.228 (port 80 must be
# open to ACME validators, otherwise cert issuance fails).

{
	email l2aggron@gmail.com
}

escros.work.gd {
	encode gzip zstd
	reverse_proxy landing:3000
}

app.escros.work.gd {
	encode gzip zstd
	reverse_proxy frontend:80
}
