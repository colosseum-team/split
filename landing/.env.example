# Public URL the "Try the demo" CTA points at. Set to the deployed
# frontend (or the demo origin) at build time, since Next inlines
# NEXT_PUBLIC_* into the client bundle.
NEXT_PUBLIC_DEMO_URL=http://localhost:5173

# Public source repository link shown in the hero secondary action and footer.
NEXT_PUBLIC_GITHUB_URL=https://github.com/colosseum-team/split
